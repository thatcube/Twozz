# macOS
.DS_Store

# Xcode — project is generated by XcodeGen from project.yml, do not commit
*.xcodeproj/
*.xcworkspace/
xcuserdata/
*.xcuserstate
*.xcscmblueprint
DerivedData/
build/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.resolved

# SweetPad / build server
buildServer.json
.sourcekit-lsp/

# Maintainer-local agent instructions (personal workflow / device IDs)
AGENTS.local.md

# Secrets — never commit Twitch client IDs/tokens
Secrets.swift
*.xcconfig.local
.env
.env.fastlane

# App Store Connect API key — never commit the private key
*.p8

# Fastlane artifacts
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
fastlane/screenshots/**/*.png

# Misc
*.log

# Apple sysdiagnose captures (never commit)
sysdiagnose_*/
sysdiagnose_*.tar.gz
