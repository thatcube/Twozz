// Copy this file to YouTubeSecrets.xcconfig.local and set your YouTube OAuth
// client credentials. This file is ignored by git because it ends with
// .xcconfig.local.
//
// Create the client in Google Cloud Console → APIs & Services → Credentials →
// "Create credentials" → OAuth client ID → application type
// "TVs and Limited Input devices" (required for the tvOS device flow).
YOUTUBE_CLIENT_ID = your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET = your_youtube_client_secret_here
